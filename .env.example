# ===== Database =====
# SQLite (default): file:./dev.db
# PostgreSQL:       postgresql://user:password@host:5432/blog_platform
DATABASE_URL="file:./dev.db"

# ===== NextAuth.js v5 =====
# ⚠️ 生产环境务必修改！Generate with: openssl rand -base64 32
# 未设置或使用默认值将导致严重安全漏洞
AUTH_SECRET="change-me-in-production-please"
# Required if AUTH_URL cannot be auto-detected
AUTH_URL="http://localhost:3000"

# ===== OAuth Providers (optional) =====
# GitHub OAuth: https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ===== SMTP (optional - for password reset emails) =====
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@blog-platform.com"

# ===== App Config =====
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AI Coding Blog"
